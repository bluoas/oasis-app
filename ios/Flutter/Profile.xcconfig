#include "Generated.xcconfig"
#include? "Pods/Target Support Files/Pods-Runner/Pods-Runner.profile.xcconfig"

// Disable dead code stripping to preserve P2P symbols
DEAD_CODE_STRIPPING = NO
STRIP_STYLE = non-global

// Force load P2P static library to expose symbols
// IMPORTANT: Use += to append, not = to override!
OTHER_LDFLAGS = $(inherited) -force_load "$(PROJECT_DIR)/Frameworks/libp2p_ios.a" -framework Security -lresolv -Wl,-export_dynamic
